# =============================================================================
# Indian Legal RAG System — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control — it is already in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Required — Groq LLM
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile
TEMPERATURE=0.2
MAX_TOKENS=1200
TIMEOUT=30

# ---------------------------------------------------------------------------
# Required — Qdrant Vector Database
# ---------------------------------------------------------------------------
QDRANT_URL=https://your-cluster-id.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
COLLECTION_NAME=legal_documents

# ---------------------------------------------------------------------------
# Required (Production) — Backend API URL for the Streamlit frontend
# ---------------------------------------------------------------------------
# Set this to your Render backend URL in production.
# Local dev default: http://127.0.0.1:8000
API_URL=https://your-backend-service.onrender.com

# ---------------------------------------------------------------------------
# CORS — Allowed origins (comma-separated)
# ---------------------------------------------------------------------------
# In production, set this to your Render frontend URL.
# Local dev default includes localhost:3000, localhost:5173, localhost:8501.
# CORS_ORIGINS=https://your-frontend-service.onrender.com,http://localhost:8501

# ---------------------------------------------------------------------------
# Optional — Server configuration
# ---------------------------------------------------------------------------
# API_HOST=0.0.0.0          # Default: 0.0.0.0 (bind all interfaces)
# API_PORT=8000              # Default: 8000 (overridden by Render's PORT)
# LOG_LEVEL=INFO             # Default: INFO (options: DEBUG, INFO, WARNING, ERROR)

# ---------------------------------------------------------------------------
# Optional — Retrieval tuning
# ---------------------------------------------------------------------------
# DEFAULT_TOP_K=10
# DENSE_TOP_K=20
# BM25_TOP_K=20
# RRF_K=60
# FUSION_STRATEGY=rrf
# DENSE_WEIGHT=0.5
# BM25_WEIGHT=0.5

# ---------------------------------------------------------------------------
# Optional — Reranker tuning
# ---------------------------------------------------------------------------
# RERANKER_MODEL_NAME=BAAI/bge-reranker-base
# RERANKER_TOP_K=5
# RERANKER_BATCH_SIZE=32
# RERANKER_DEVICE=auto
# RERANKER_MAX_LENGTH=512

# ---------------------------------------------------------------------------
# Optional — Pipeline tuning
# ---------------------------------------------------------------------------
# AGENT_RETRIEVER_TOP_K=20
# AGENT_RERANKER_TOP_K=5
# AGENT_MAX_ITERATIONS=5
# CONFIDENCE_THRESHOLD=0.3

# ---------------------------------------------------------------------------
# Optional — Indexer tuning (only for create_indexes.py / src/indexer.py)
# ---------------------------------------------------------------------------
# INDEXING_BATCH_SIZE=100
# MAX_UPSERT_RETRIES=3
# RETRY_BACKOFF_SECONDS=1.0
